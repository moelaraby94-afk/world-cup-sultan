<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <title>إضافة توقع - مسابقة كأس العالم</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/styles.css">
  <style>
    .ms-date-pill { flex-shrink:0; padding:7px 14px; border-radius:20px; font-size:12px; font-weight:700; color:rgba(255,255,255,0.6); background:rgba(255,255,255,0.07); border:1px solid rgba(255,255,255,0.1); cursor:pointer; transition:all 0.2s; white-space:nowrap; }
    .ms-date-pill.active { background:#F59E0B; color:#0b132a; border-color:#F59E0B; }
    .sc-date-pill { font-size:12px; font-weight:700; cursor:pointer; white-space:nowrap; }
    .pr-date-filters { display:flex; gap:6px; flex-wrap:wrap; }

    /* ===== Tab Bar ===== */
    .pred-tab-bar { display:flex; gap:0; margin:0 auto 16px; max-width:520px; border-radius:14px; overflow:hidden; border:1px solid rgba(255,255,255,0.12); background:rgba(255,255,255,0.05); }
    .pred-tab { flex:1; display:flex; align-items:center; justify-content:center; gap:8px; padding:14px 10px; border:none; background:transparent; color:rgba(255,255,255,0.5); font-size:0.92rem; font-weight:800; cursor:pointer; transition:all 0.2s; text-decoration:none; white-space:nowrap; }
    .pred-tab svg { width:18px; height:18px; flex-shrink:0; }
    .pred-tab.active { background:linear-gradient(135deg,#F59E0B,#d49715); color:#0b132a; }
    .pred-tab:not(.active):hover { background:rgba(255,255,255,0.07); color:rgba(255,255,255,0.8); }
    .pred-tab-content { display:none; }
    .pred-tab-content.active { display:block; }

    /* ===== Challenge (inline) ===== */
    .ch-inline { max-width:720px; margin:0 auto; }
    .ch-inline-hero { text-align:center; margin-bottom:20px; }
    .ch-inline-hero-title { font-size:1.3rem; font-weight:900; color:#F59E0B; margin-bottom:6px; }
    .ch-inline-hero-desc { font-size:0.85rem; color:rgba(255,255,255,0.55); }
    .ch-inline-countdown { text-align:center; padding:14px; background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1); border-radius:14px; margin-bottom:20px; }
    .ch-inline-countdown-lbl { font-size:0.8rem; color:rgba(255,255,255,0.5); margin-bottom:4px; }
    .ch-inline-countdown-val { font-size:2rem; font-weight:900; color:#ef4444; font-family:monospace; letter-spacing:2px; }
    .ch-inline-closed { display:inline-block; padding:8px 20px; background:#ef4444; color:#fff; border-radius:10px; font-weight:800; font-size:0.9rem; }
    .ch-inline-info { background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.1); border-radius:14px; padding:14px 16px; margin-bottom:16px; font-size:0.82rem; color:rgba(255,255,255,0.6); }
    .ch-inline-info-title { font-weight:800; color:rgba(255,255,255,0.85); margin-bottom:8px; }
    .ch-inline-info-badges { display:flex; gap:8px; flex-wrap:wrap; }
    .ch-inline-info-badge { background:rgba(212,175,55,0.12); padding:4px 12px; border-radius:8px; font-weight:600; color:#d4af37; }
    .ch-inline-saved { text-align:center; padding:12px; background:rgba(34,197,94,0.1); border:1px solid rgba(34,197,94,0.3); border-radius:10px; color:#22c55e; font-weight:800; font-size:0.9rem; margin-bottom:16px; }
    .ch-inline-edit-btn { display:inline-block; padding:8px 24px; background:var(--primary,#6366f1); color:#fff; font-weight:800; border:none; border-radius:10px; cursor:pointer; font-size:0.88rem; }
    .ch-inline-section { background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.1); border-radius:14px; padding:16px; margin-bottom:16px; }
    .ch-inline-section-title { font-size:1rem; font-weight:800; color:rgba(255,255,255,0.9); margin-bottom:4px; }
    .ch-inline-section-desc { font-size:0.8rem; color:rgba(255,255,255,0.5); margin-bottom:10px; }
    .ch-inline-section-points { display:inline-block; background:rgba(212,175,55,0.15); color:#d4af37; padding:2px 10px; border-radius:20px; font-size:0.75rem; font-weight:800; margin-bottom:12px; }
    .ch-inline-pick-info { display:flex; justify-content:space-between; align-items:center; font-size:0.8rem; color:rgba(255,255,255,0.5); margin-bottom:8px; }
    .ch-inline-pick-count { font-weight:800; }
    .ch-inline-pick-count.valid { color:#22c55e; }
    .ch-inline-pick-count.invalid { color:#ef4444; }
    .ch-inline-team-grid { display:flex; flex-wrap:wrap; gap:6px; }
    .ch-inline-team { display:flex; align-items:center; gap:6px; padding:6px 12px; border:2px solid rgba(255,255,255,0.12); border-radius:10px; cursor:pointer; transition:all 0.15s; user-select:none; font-size:0.82rem; font-weight:600; background:rgba(255,255,255,0.03); color:rgba(255,255,255,0.7); }
    .ch-inline-team:hover { border-color:rgba(99,102,241,0.5); background:rgba(99,102,241,0.08); }
    .ch-inline-team.selected { border-color:#22c55e; background:rgba(34,197,94,0.12); color:#22c55e; }
    .ch-inline-team.disabled { opacity:0.4; cursor:not-allowed; }
    .ch-inline-team-flag { width:20px; height:14px; object-fit:cover; border-radius:2px; }
    .ch-inline-save-btn { display:block; width:100%; padding:14px; border:none; border-radius:12px; font-size:1rem; font-weight:800; cursor:pointer; transition:opacity 0.15s; margin-top:8px; background:linear-gradient(135deg,#22c55e,#16a34a); color:#fff; }
    .ch-inline-save-btn:disabled { opacity:0.5; cursor:not-allowed; }
    .ch-inline-closed-stage { text-align:center; padding:24px; background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.1); border-radius:14px; margin-bottom:16px; color:rgba(255,255,255,0.5); font-size:0.95rem; font-weight:700; }
    @media (max-width:600px) {
      .pred-tab { font-size:0.82rem; padding:12px 6px; }
      .pred-tab svg { width:16px; height:16px; }
      .ch-inline-team { padding:5px 10px; font-size:0.78rem; }
    }
  </style>
</head>
<body>
  <div class="app-shell">
    <%- include('partials/sidebar', { active: 'predictions', user: user, top3: top3 }) %>
    <main class="main-content">
      <section class="page-content">

        <% if (typeof message !== 'undefined' && message) { %>
          <div class="pc-message"><%= message %></div>
        <% } %>

        <!-- ===== MOBILE PREDICTIONS (≤860px) ===== -->
        <div class="pc2">

          <!-- Header -->
          <div class="pc2-header">
            <div class="pc2-header-bg"></div>
            <div class="pc2-header-inner">
              <button class="pc2-menu-btn" data-mobile-menu-trigger aria-label="فتح القائمة">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="4" y1="6" x2="20" y2="6"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="18" x2="20" y2="18"/></svg>
              </button>
              <div class="pc2-logo">
                <img src="/logo.png" alt="شعار" style="width:72px;height:72px;object-fit:contain;filter:drop-shadow(0 4px 16px rgba(0,0,0,0.4));">
              </div>
              <span class="pc2-guide-btn" onclick="window.location='/rules'">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
                دليل التوقع
              </span>
            </div>
            <h1 class="pc2-header-title">إضافة توقعات الجولة</h1>
            <p class="pc2-header-sub">توقع نتائج جميع مباريات الجولة</p>

            <!-- Tab Bar -->
            <div class="pred-tab-bar">
              <button class="pred-tab <%= activeTab === 'matches' ? 'active' : '' %>" onclick="predSwitchTab('matches')" id="predTabMatches">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="2" x2="12" y2="22"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                توقع المباريات
              </button>
              <button class="pred-tab <%= activeTab === 'challenge' ? 'active' : '' %>" onclick="predSwitchTab('challenge')" id="predTabChallenge">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/></svg>
                لعبة التحدي
              </button>
            </div>

          </div>

          <!-- ===== Matches Tab Content (Mobile) ===== -->
          <div class="pred-tab-content <%= activeTab === 'matches' ? 'active' : '' %>" id="predTabContentMatches">

            <!-- Round Selector (moved inside tab) -->
            <div class="pc2-round-selector" id="pc2RoundSelector" style="margin-top:16px;">
              <%
                var pc2Rounds = {};
                matches.forEach(function(item){
                  var r = item.match.round || 1;
                  var stage = item.match.stage || '';
                  if (!pc2Rounds[r]) pc2Rounds[r] = stage;
                });
                var pc2RoundKeys = Object.keys(pc2Rounds).sort(function(a,b){return a-b;});
                var pc2ActiveRound = pc2RoundKeys[0] || '1';
              %>
              <button class="pc2-round-btn" id="pc2RoundBtn" onclick="pc2ToggleRounds()">
                <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M4 6h16M4 12h16M4 18h16" stroke="currentColor" stroke-width="2" fill="none"/></svg>
                <span id="pc2RoundBtnLabel">
                  <% if (pc2RoundKeys.length > 0) { %>
                    <%= pc2Rounds[pc2ActiveRound] ? pc2Rounds[pc2ActiveRound] + ' - ' : '' %>الجولة <%= pc2ActiveRound %>
                  <% } else { %>
                    الجولة 1
                  <% } %>
                </span>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="14" height="14"><polyline points="6 9 12 15 18 9"/></svg>
              </button>
              <div class="pc2-round-dropdown" id="pc2RoundDropdown" style="display:none;">
                <% pc2RoundKeys.forEach(function(r){ %>
                <button class="pc2-round-opt <%= r == pc2ActiveRound ? 'active' : '' %>"
                  onclick="pc2SelectRound('<%= r %>', '<%= (pc2Rounds[r] ? pc2Rounds[r] + ' - ' : '') + 'الجولة ' + r %>')">
                  <%= pc2Rounds[r] ? pc2Rounds[r] + ' — ' : '' %>الجولة <%= r %>
                </button>
                <% }); %>
              </div>
            </div>
          </div>

          <!-- Alert -->
          <div class="pc2-alert">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            <span>يغلق التوقع تلقائياً قبل بداية كل مباراة بـ 10 دقائق</span>
          </div>

          <!-- Date Filters (mobile) -->
          <div class="ms2-group-wrap" style="margin-top:0;">
            <div class="ms2-group-scroll">
              <button class="ms-date-pill active" data-pc2-date="all" onclick="pc2DateFilter('all',this)">الكل</button>
              <button class="ms-date-pill" data-pc2-date="yesterday" onclick="pc2DateFilter('yesterday',this)">أمس</button>
              <button class="ms-date-pill" data-pc2-date="today" onclick="pc2DateFilter('today',this)">اليوم</button>
              <button class="ms-date-pill" data-pc2-date="tomorrow" onclick="pc2DateFilter('tomorrow',this)">غداً</button>
            </div>
          </div>

          <!-- Match Cards -->
          <%
            var pc2ByRound = {};
            matches.forEach(function(item){
              var r = item.match.round || 1;
              if (!pc2ByRound[r]) pc2ByRound[r] = [];
              pc2ByRound[r].push(item);
            });
            var pc2Sorted = Object.keys(pc2ByRound).sort(function(a,b){return a-b;});
          %>

          <% if (matches.length === 0) { %>
            <div class="pc2-empty">
              <div class="pc2-empty-icon">⚽</div>
              <p>لا توجد مباريات متاحة</p>
            </div>
          <% } else { %>
            <% pc2Sorted.forEach(function(round){ %>
            <div class="pc2-round-group" id="pc2Group<%= round %>" data-round="<%= round %>">
              <% pc2ByRound[round].forEach(function(item, idx){ %>
              <%
                var m = item.match;
                var locked = item.locked;
                var ended = m.actual_scoreA != null;
                var saved = item.prediction != null;
                var valA = saved ? item.prediction.scoreA : 0;
                var valB = saved ? item.prediction.scoreB : 0;
                var pc2Date = new Date(m.start_at).toLocaleDateString('en-CA', { timeZone: 'Asia/Riyadh' });
              %>
              <div class="pc2-card <%= locked && !ended ? 'pc2-card-locked' : '' %> <%= ended ? 'pc2-card-ended' : '' %> <%= saved && !ended ? 'pc2-card-saved' : '' %> <%= m.round >= 4 ? 'pc2-ko' : '' %>" id="pc2Card<%= m.id %>" data-pc2-date="<%= pc2Date %>">

                <!-- Card Top: stage + date + time -->
                <div class="pc2-card-top">
                  <span class="pc2-card-stage"><%= m.stage || 'دوري المجموعات' %></span>
                  <div class="pc2-card-meta">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="12" height="12"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                    <span><%= new Date(m.start_at).toLocaleDateString('ar-SA',{weekday:'long',month:'long',day:'numeric',timeZone:'Asia/Riyadh'}) %></span>
                    <span class="pc2-card-time-badge">م <%= new Date(m.start_at).toLocaleTimeString('ar-EG',{hour:'2-digit',minute:'2-digit',timeZone:'Asia/Riyadh'}) %></span>
                  </div>
                </div>

                <!-- Teams + Stepper -->
                <div class="pc2-card-mid">
                  <!-- Team A -->
                  <div class="pc2-team">
                    <img src="/flags/<%= teamFlags[m.teamA] || 'unknown' %>.png" alt="<%= m.teamA %>" onerror="this.src='/flags/unknown.png'" class="pc2-flag">
                    <span class="pc2-team-name"><%= m.teamA %></span>
                  </div>

                  <!-- Prediction Display / Score Stepper -->
                  <% if (ended) { %>
                    <% if (saved) { %>
                    <div class="pc2-pred-score">
                      <span class="pc2-pred-label">توقعك</span>
                      <div class="pc2-pred-score-row">
                        <span class="pc2-pred-num"><%= valA %></span>
                        <span class="pc2-score-dash">-</span>
                        <span class="pc2-pred-num"><%= valB %></span>
                      </div>
                      <% if (saved && item.prediction.penalty_winner) { %>
                      <span class="pc2-ko-pred-pk">⚽ <%= item.prediction.penalty_winner %></span>
                      <% } %>
                    </div>
                    <% } else { %>
                    <div class="pc2-pred-none">
                      <span>لم تسجل توقعك</span>
                    </div>
                    <% } %>
                  <% } else { %>
                    <form method="POST" action="/predictions" class="pc2-form" id="pc2Form<%= m.id %>">
                      <input type="hidden" name="matchId" value="<%= m.id %>">
                      <input type="hidden" name="scoreA" id="pc2A<%= m.id %>" value="<%= valA %>">
                      <input type="hidden" name="scoreB" id="pc2B<%= m.id %>" value="<%= valB %>">
                      <div class="pc2-stepper">
                        <div class="pc2-step-col">
                          <button type="button" class="pc2-step-up" onclick="pc2Step(<%= m.id %>,'A',1)" <%= locked ? 'disabled' : '' %>>&#9650;</button>
                          <span class="pc2-step-num" id="pc2VA<%= m.id %>"><%= valA %></span>
                          <button type="button" class="pc2-step-dn" onclick="pc2Step(<%= m.id %>,'A',-1)" <%= locked ? 'disabled' : '' %>>&#9660;</button>
                        </div>
                        <span class="pc2-step-dash">-</span>
                        <div class="pc2-step-col">
                          <button type="button" class="pc2-step-up" onclick="pc2Step(<%= m.id %>,'B',1)" <%= locked ? 'disabled' : '' %>>&#9650;</button>
                          <span class="pc2-step-num" id="pc2VB<%= m.id %>"><%= valB %></span>
                          <button type="button" class="pc2-step-dn" onclick="pc2Step(<%= m.id %>,'B',-1)" <%= locked ? 'disabled' : '' %>>&#9660;</button>
                        </div>
                      </div>
                    </form>

                  <% } %>

                  <!-- Team B -->
                  <div class="pc2-team">
                    <img src="/flags/<%= teamFlags[m.teamB] || 'unknown' %>.png" alt="<%= m.teamB %>" onerror="this.src='/flags/unknown.png'" class="pc2-flag">
                    <span class="pc2-team-name"><%= m.teamB %></span>
                  </div>
                </div>

                <!-- ⚽ KO: ركلات الترجيح -->
                <% if (m.round >= 4 && !ended && !locked) { %>
                <div class="pc2-ko-penalty" id="pc2Penalty<%= m.id %>" style="display:none;">
                  <span class="pc2-ko-pen-label">⚽ من يفوز بالترجيح؟</span>
                  <div class="pc2-ko-pen-opts">
                    <label class="pc2-ko-pen-opt <%= saved && item.prediction && item.prediction.penalty_winner === m.teamA ? 'pc2-ko-pen-selected' : '' %>">
                      <input type="radio" name="penaltyWinner" value="<%= m.teamA %>"
                        id="ppen<%= m.id %>A" form="pc2Form<%= m.id %>" style="display:none"
                        <%= saved && item.prediction && item.prediction.penalty_winner === m.teamA ? 'checked' : '' %>
                        onchange="document.querySelectorAll('#pc2Card<%= m.id %> .pc2-ko-pen-opt').forEach(function(l){l.classList.remove('pc2-ko-pen-selected')});this.closest('.pc2-ko-pen-opt').classList.add('pc2-ko-pen-selected')">
                      <img src="/flags/<%= teamFlags[m.teamA]||'unknown' %>.png" class="pc2-ko-pen-flag" onerror="this.src='/flags/unknown.png'">
                      <span class="pc2-ko-pen-name"><%= m.teamA %></span>
                    </label>
                    <label class="pc2-ko-pen-opt <%= saved && item.prediction && item.prediction.penalty_winner === m.teamB ? 'pc2-ko-pen-selected' : '' %>">
                      <input type="radio" name="penaltyWinner" value="<%= m.teamB %>"
                        id="ppen<%= m.id %>B" form="pc2Form<%= m.id %>" style="display:none"
                        <%= saved && item.prediction && item.prediction.penalty_winner === m.teamB ? 'checked' : '' %>
                        onchange="document.querySelectorAll('#pc2Card<%= m.id %> .pc2-ko-pen-opt').forEach(function(l){l.classList.remove('pc2-ko-pen-selected')});this.closest('.pc2-ko-pen-opt').classList.add('pc2-ko-pen-selected')">
                      <img src="/flags/<%= teamFlags[m.teamB]||'unknown' %>.png" class="pc2-ko-pen-flag" onerror="this.src='/flags/unknown.png'">
                      <span class="pc2-ko-pen-name"><%= m.teamB %></span>
                    </label>
                  </div>
                </div>
                <% } %>

                <!-- Card Footer -->
                <div class="pc2-card-foot">
                  <% if (ended) { %>
                    <span class="pc2-foot-ended">
                      <svg viewBox="0 0 24 24" fill="currentColor" width="14" height="14"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
                      انتهت المباراة · <%= m.actual_scoreA %>-<%= m.actual_scoreB %>
                    </span>
                    <% if (!saved) { %>
                    <span class="pc2-foot-nopred">لم تسجل توقعك</span>
                    <% } %>
                  <% } else if (locked) { %>
                    <span class="pc2-foot-locked">
                      <svg viewBox="0 0 24 24" fill="currentColor" width="14" height="14"><path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2z"/></svg>
                      التوقع مغلق
                    </span>
                  <% } else { %>
                    <button type="submit" class="pc2-save-btn" id="pc2Btn<%= m.id %>" form="pc2Form<%= m.id %>" onclick="pc2Submit(<%= m.id %>)">
                      <svg viewBox="0 0 24 24" fill="currentColor" width="15" height="15"><path d="M17 3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V7l-4-4zm-5 16c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3zm3-10H5V5h10v4z"/></svg>
                      <%= saved ? 'تحديث التوقع' : 'حفظ التوقع' %>
                    </button>
                  <% } %>
                </div>

              </div>
              <% }); %>
            </div>
            <% }); %>
          <% } %>

          <!-- Show More -->
          <div class="pc2-show-more" id="pc2ShowMore" style="display:none;">
            <button onclick="pc2LoadMore()">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><polyline points="6 9 12 15 18 9"/></svg>
              عرض المزيد من المباريات
            </button>
          </div>

          <!-- Points Bar -->
          <div class="pc2-pts-bar">
            <div class="pc2-pts-item">
              <span class="pc2-pts-num">25</span>
              <span class="pc2-pts-desc">توقع النتيجة الصحيحة<br><small style="color:rgba(255,255,255,0.4)">(الإقصائيات)</small></span>
            </div>
            <div class="pc2-pts-sep"></div>
            <div class="pc2-pts-item">
              <span class="pc2-pts-num">20</span>
              <span class="pc2-pts-desc">توقع النتيجة الصحيحة<br><small style="color:rgba(255,255,255,0.4)">(المجموعات)</small></span>
            </div>
            <div class="pc2-pts-sep"></div>
            <div class="pc2-pts-item">
              <span class="pc2-pts-num">15</span>
              <span class="pc2-pts-desc">توقع الفارق الصحيح</span>
            </div>
            <div class="pc2-pts-sep"></div>
            <div class="pc2-pts-item">
              <span class="pc2-pts-num">10</span>
              <span class="pc2-pts-desc">توقع الاتجاه الصحيح</span>
            </div>
            <div class="pc2-pts-sep"></div>
            <div class="pc2-pts-item">
              <span class="pc2-pts-num">+5</span>
              <span class="pc2-pts-desc">ركلات الترجيح<br><small style="color:rgba(255,255,255,0.4)">(للتعادل فقط)</small></span>
            </div>
            <a href="/rules" class="pc2-pts-link">
              <svg viewBox="0 0 24 24" fill="currentColor" width="14" height="14"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
              نظام النقاط
            </a>
          </div>

          </div><!-- end matches tab content (mobile) -->

          <!-- ===== Challenge Tab Content (Mobile) ===== -->
          <div class="pred-tab-content <%= activeTab === 'challenge' ? 'active' : '' %>" id="predTabContentChallenge">
            <div class="ch-inline">

              <div class="ch-inline-hero">
                <div class="ch-inline-hero-title">🏆 توقع واربح المزيد من النقاط</div>
                <div class="ch-inline-hero-desc">توقع مستقبل البطولة واحصل على نقاط إضافية عند صحة توقعاتك</div>
              </div>

              <% if (challengeConfig && challengeConfig.open) { %>
              <div class="ch-inline-countdown">
                <div class="ch-inline-countdown-lbl">⏳ الوقت المتبقي لإغلاق التحدي</div>
                <div class="ch-inline-countdown-val" id="chInlineCountdown">--:--:--</div>
              </div>
              <% } else { %>
              <div style="text-align:center;margin-bottom:20px;">
                <span class="ch-inline-closed">🔒 التحدي مغلق</span>
              </div>
              <% } %>

              <div class="ch-inline-info">
                <div class="ch-inline-info-title">📊 آلية احتساب النقاط</div>
                <div class="ch-inline-info-badges">
                  <span class="ch-inline-info-badge">دور الـ8: 5 نقاط لكل منتخب</span>
                  <span class="ch-inline-info-badge">دور الـ4: 10 نقاط لكل منتخب</span>
                  <span class="ch-inline-info-badge">طرفا النهائي: 15 نقطة لكل منتخب</span>
                  <span class="ch-inline-info-badge">البطل: 20 نقطة</span>
                </div>
              </div>

              <% if (challengeSaved) { %>
              <div class="ch-inline-saved">✅ تم حفظ توقعاتك بنجاح</div>
              <% } %>

              <% if (challengePicks && challengePicks.qf && challengeConfig && challengeConfig.open) { %>
              <div style="text-align:center;margin-bottom:16px;">
                <button type="button" class="ch-inline-edit-btn" onclick="chInlineToggleEdit()">✏️ تعديل التوقعات</button>
                <div style="font-size:0.78rem;color:rgba(255,255,255,0.4);margin-top:4px;">تم حفظ توقعاتك سابقاً — يمكنك تعديلها حتى موعد الإغلاق</div>
              </div>
              <% } %>

              <div id="chInlineEditArea" <%= (challengePicks && challengePicks.qf && challengeConfig && challengeConfig.open) ? 'style="display:none"' : '' %>>
              <form id="chInlineForm" method="POST" action="/challenge/save">
                <input type="hidden" name="source" value="predictions">

                <!-- Section 1: دور الـ8 -->
                <div class="ch-inline-section">
                  <div class="ch-inline-section-title">🎯 توقع المنتخبات المتأهلة إلى دور الـ8</div>
                  <div class="ch-inline-section-desc">اختر 8 منتخبات من القائمة</div>
                  <span class="ch-inline-section-points">5 نقاط لكل منتخب صحيح</span>
                  <div class="ch-inline-pick-info">
                    <span>المختار: <span class="ch-inline-pick-count" id="chInlineQfCount">0</span>/8</span>
                  </div>
                  <div class="ch-inline-team-grid" id="chInlineQfGrid">
                    <% challengeTeams.forEach(function(t) { %>
                    <div class="ch-inline-team" data-team="<%= t %>" data-section="qf" onclick="chInlineToggleTeam(this,'qf',8)">
                      <img src="/flags/<%= teamFlags[t] || 'unknown' %>.png" class="ch-inline-team-flag" onerror="this.style.display='none'">
                      <%= t %>
                      <input type="checkbox" name="qf" value="<%= t %>" style="display:none" <%= challengePicks && challengePicks.qf && challengePicks.qf.includes(t) ? 'checked' : '' %>>
                    </div>
                    <% }) %>
                  </div>
                </div>

                <!-- Section 2: دور الـ4 -->
                <div class="ch-inline-section">
                  <div class="ch-inline-section-title">🎯 توقع المنتخبات المتأهلة إلى دور الـ4</div>
                  <div class="ch-inline-section-desc">اختر 4 منتخبات من القائمة</div>
                  <span class="ch-inline-section-points">10 نقاط لكل منتخب صحيح</span>
                  <div class="ch-inline-pick-info">
                    <span>المختار: <span class="ch-inline-pick-count" id="chInlineSfCount">0</span>/4</span>
                  </div>
                  <div class="ch-inline-team-grid" id="chInlineSfGrid">
                    <% challengeTeams.forEach(function(t) { %>
                    <div class="ch-inline-team" data-team="<%= t %>" data-section="sf" onclick="chInlineToggleTeam(this,'sf',4)">
                      <img src="/flags/<%= teamFlags[t] || 'unknown' %>.png" class="ch-inline-team-flag" onerror="this.style.display='none'">
                      <%= t %>
                      <input type="checkbox" name="sf" value="<%= t %>" style="display:none" <%= challengePicks && challengePicks.sf && challengePicks.sf.includes(t) ? 'checked' : '' %>>
                    </div>
                    <% }) %>
                  </div>
                </div>

                <!-- Section 3: طرفا النهائي -->
                <div class="ch-inline-section">
                  <div class="ch-inline-section-title">🎯 توقع طرفي المباراة النهائية</div>
                  <div class="ch-inline-section-desc">اختر منتخبين</div>
                  <span class="ch-inline-section-points">15 نقطة لكل منتخب صحيح</span>
                  <div class="ch-inline-pick-info">
                    <span>المختار: <span class="ch-inline-pick-count" id="chInlineFinalistsCount">0</span>/2</span>
                  </div>
                  <div class="ch-inline-team-grid" id="chInlineFinalistsGrid">
                    <% challengeTeams.forEach(function(t) { %>
                    <div class="ch-inline-team" data-team="<%= t %>" data-section="finalists" onclick="chInlineToggleTeam(this,'finalists',2)">
                      <img src="/flags/<%= teamFlags[t] || 'unknown' %>.png" class="ch-inline-team-flag" onerror="this.style.display='none'">
                      <%= t %>
                      <input type="checkbox" name="finalists" value="<%= t %>" style="display:none" <%= challengePicks && challengePicks.finalists && challengePicks.finalists.includes(t) ? 'checked' : '' %>>
                    </div>
                    <% }) %>
                  </div>
                </div>

                <!-- Section 4: البطل -->
                <div class="ch-inline-section">
                  <div class="ch-inline-section-title">🏆 توقع بطل كأس العالم</div>
                  <div class="ch-inline-section-desc">اختر منتخب واحد</div>
                  <span class="ch-inline-section-points">20 نقطة إذا كان الاختيار صحيحاً</span>
                  <div class="ch-inline-pick-info">
                    <span>المختار: <span class="ch-inline-pick-count" id="chInlineChampionCount">0</span>/1</span>
                  </div>
                  <div class="ch-inline-team-grid" id="chInlineChampionGrid">
                    <% challengeTeams.forEach(function(t) { %>
                    <div class="ch-inline-team" data-team="<%= t %>" data-section="champion" onclick="chInlineToggleTeam(this,'champion',1)">
                      <img src="/flags/<%= teamFlags[t] || 'unknown' %>.png" class="ch-inline-team-flag" onerror="this.style.display='none'">
                      <%= t %>
                      <input type="checkbox" name="champion" value="<%= t %>" style="display:none" <%= challengePicks && challengePicks.champion && challengePicks.champion === t ? 'checked' : '' %>>
                    </div>
                    <% }) %>
                  </div>
                </div>

                <button type="submit" class="ch-inline-save-btn" id="chInlineSaveBtn" <%= !challengeConfig || !challengeConfig.open ? 'disabled' : '' %>>
                  <%= challengePicks && challengePicks.qf ? '💾 تحديث التوقعات' : '💾 حفظ التحدي' %>
                </button>
              </form>
              </div>

              <% if (!challengeConfig || !challengeConfig.open) { %>
              <% if (challengePicks && challengePicks.qf) { %>
              <div class="ch-inline-closed-stage">
                ✅ تم حفظ توقعاتك مسبقاً. هذه المرحلة غير متاحة حالياً للتعديل.
              </div>
              <% } else { %>
              <div class="ch-inline-closed-stage">
                هذه المرحلة غير متاحة حالياً
              </div>
              <% } %>
              <% } %>

            </div>
          </div><!-- end challenge tab content (mobile) -->

        </div>

        <!-- ===== DESKTOP PREDICTIONS (≥861px) ===== -->
        <div class="pc-desktop">

        <!-- Topbar -->
        <header class="pr-topbar">
          <div class="pr-topbar-right">
            <p class="pr-topbar-label">الصفحة الحالية</p>
            <h1 class="pr-topbar-title">إضافة توقع</h1>
          </div>
          <div class="pr-topbar-date">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            <%= new Date().toLocaleDateString('ar-SA', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric', timeZone: 'Asia/Riyadh' }) %>
          </div>
        </header>

        <!-- Stats Bar -->
        <div class="pr-stats">
          <div class="pr-stat-card">
            <div class="pr-stat-icon pr-stat-blue">
              <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/></svg>
            </div>
            <div class="pr-stat-info">
              <span class="pr-stat-num"><%= totalPlayers.toLocaleString('ar-EG') %></span>
              <span class="pr-stat-lbl">عدد المشاركين</span>
            </div>
          </div>
          <div class="pr-stat-card">
            <div class="pr-stat-icon pr-stat-blue">
              <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22"><path d="M3.5 18.49l6-6.01 4 4L22 6.92l-1.41-1.41-7.09 7.97-4-4L2 16.99z"/></svg>
            </div>
            <div class="pr-stat-info">
              <span class="pr-stat-num"><%= predictionsCount.toLocaleString('ar-EG') %></span>
              <span class="pr-stat-lbl">التوقعات المسجلة</span>
            </div>
          </div>
          <div class="pr-stat-card">
            <div class="pr-stat-icon pr-stat-blue">
              <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/></svg>
            </div>
            <div class="pr-stat-info">
              <span class="pr-stat-num"><%= allMatchesCount %></span>
              <span class="pr-stat-lbl">عدد المباريات</span>
            </div>
          </div>
          <div class="pr-stat-card pr-stat-highlight">
            <div class="pr-stat-icon pr-stat-gold">
              <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
            </div>
            <div class="pr-stat-info">
              <span class="pr-stat-num"><%= userRank > 0 ? userRank : '-' %></span>
              <span class="pr-stat-lbl">ترتيبك الحالي</span>
            </div>
          </div>
          <div class="pr-stat-card">
            <div class="pr-stat-icon pr-stat-green">
              <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
            </div>
            <div class="pr-stat-info">
              <span class="pr-stat-num"><%= userPoints.toLocaleString('ar-EG') %></span>
              <span class="pr-stat-lbl">نقاطك الحالية</span>
            </div>
          </div>
          <div class="pr-stat-card" style="<%= missedPredictions > 0 ? 'border-color:#ef4444;background:rgba(239,68,68,0.06);' : 'border-color:#22c55e;background:rgba(34,197,94,0.06);' %>">
            <div class="pr-stat-icon" style="background:<%= missedPredictions > 0 ? 'rgba(239,68,68,0.15)' : 'rgba(34,197,94,0.15)' %>;color:<%= missedPredictions > 0 ? '#ef4444' : '#22c55e' %>;">
              <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
            </div>
            <div class="pr-stat-info">
              <span class="pr-stat-num" style="color:<%= missedPredictions > 0 ? '#ef4444' : '#22c55e' %>;"><%= missedPredictions %></span>
              <span class="pr-stat-lbl">مباريات فائتة</span>
            </div>
          </div>
          <div class="pr-stat-card">
            <div class="pr-stat-icon" style="background:<%= commitmentRate >= 80 ? 'rgba(34,197,94,0.15)' : 'rgba(239,68,68,0.15)' %>;color:<%= commitmentRate >= 80 ? '#22c55e' : '#ef4444' %>;">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            </div>
            <div class="pr-stat-info">
              <span class="pr-stat-num" style="color:<%= commitmentRate >= 80 ? '#22c55e' : '#ef4444' %>;"><%= commitmentRate %>%</span>
              <span class="pr-stat-lbl">نسبة الالتزام</span>
            </div>
          </div>
        </div>

        <!-- Tab Bar (Desktop) -->
        <div class="pred-tab-bar" style="margin-bottom:20px;">
          <button class="pred-tab <%= activeTab === 'matches' ? 'active' : '' %>" onclick="predSwitchTab('matches')" id="predTabMatchesDesktop">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="2" x2="12" y2="22"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
            توقع المباريات
          </button>
          <button class="pred-tab <%= activeTab === 'challenge' ? 'active' : '' %>" onclick="predSwitchTab('challenge')" id="predTabChallengeDesktop">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/></svg>
            لعبة التحدي
          </button>
        </div>

        <!-- ===== Matches Tab Content (Desktop) ===== -->
        <div class="pred-tab-content <%= activeTab === 'matches' ? 'active' : '' %>" id="predTabContentMatchesDesktop">

        <!-- Matches (Desktop) -->
        <div class="pr-toolbar">
          <div class="pr-toolbar-right">
            <span class="pr-toolbar-title"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>جميع المباريات</span>
            <span class="pr-toolbar-count"><%= matches.length %></span>
          </div>
          <div class="pr-toolbar-left">
            <button class="pr-view-btn active" id="pr-list-btn" onclick="prSetView('list')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg></button>
            <button class="pr-view-btn" id="pr-grid-btn" onclick="prSetView('grid')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg></button>
          </div>
        </div>

        <%
          var prByRound = {};
          matches.forEach(function(itm){ var r=itm.match.round||1; if(!prByRound[r]) prByRound[r]=[]; prByRound[r].push(itm); });
          var prRounds = Object.keys(prByRound).sort(function(a,b){return a-b});
        %>

        <div class="pr-filters" id="pr-filters">
          <button class="pr-filter-pill active" onclick="prFilterRound('all',this)">الكل</button>
          <% prRounds.forEach(function(r){ %>
          <button class="pr-filter-pill" onclick="prFilterRound(<%= r %>,this)">الجولة <%= r %></button>
          <% }); %>
        </div>

        <!-- Date Filters (desktop) -->
        <div class="pr-filters pr-date-filters" style="margin-top:8px;">
          <button class="pr-filter-pill sc-date-pill active" data-pr-date="all" onclick="prDateFilter('all',this)">الكل</button>
          <button class="pr-filter-pill sc-date-pill" data-pr-date="yesterday" onclick="prDateFilter('yesterday',this)">أمس</button>
          <button class="pr-filter-pill sc-date-pill" data-pr-date="today" onclick="prDateFilter('today',this)">اليوم</button>
          <button class="pr-filter-pill sc-date-pill" data-pr-date="tomorrow" onclick="prDateFilter('tomorrow',this)">غداً</button>
        </div>

        <div class="pr-matches-container" id="pr-matches-container">
          <% prRounds.forEach(function(round){ %>
            <div class="pr-round-group" data-round="<%= round %>">
              <div class="pr-round-header"><span class="pr-round-badge">الجولة <%= round %></span><span class="pr-round-count"><%= prByRound[round].length %> مباراة</span></div>
              <div class="pr-matches-list">
                <% prByRound[round].forEach(function(itm){ var lck=itm.locked; var hasP=itm.prediction!=null; var ended=itm.match.actual_scoreA!=null; var prDateKey=new Date(itm.match.start_at).toLocaleDateString('en-CA',{timeZone:'Asia/Riyadh'}); %>
                <div class="pr-match-row <%= lck ? 'pr-match-locked' : '' %> <%= itm.match.round >= 4 ? 'pr-match-ko' : '' %>" data-round="<%= round %>" data-pr-date="<%= prDateKey %>">
                  <div class="pr-row-top">
                    <span class="pr-group-badge"><%= itm.match.stage %></span>
                    <span class="pr-row-time"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="13" height="13"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg><%= new Date(itm.match.start_at).toLocaleTimeString('ar-EG', { hour:'2-digit', minute:'2-digit', timeZone:'Asia/Riyadh' }) %></span>
                    <% if (ended) { %><span class="pr-row-result">انتهت <%= itm.match.actual_scoreA %>-<%= itm.match.actual_scoreB %></span><% } %>
                  </div>
                  <div class="pr-row-body">
                    <div class="pr-row-team pr-row-team-a">
                      <div class="pr-flag-wrap"><img src="/flags/<%= teamFlags[itm.match.teamA]||'unknown' %>.png" class="pr-flag" onerror="this.src='/flags/unknown.png'" /></div>
                      <span class="pr-team-name"><%= itm.match.teamA %></span>
                    </div>
                    <div class="pr-row-center">
                      <% if (ended) { %>
                        <% if (hasP) { %>
                        <div class="pr-pred-display">
                          <span class="pr-pred-label">توقعك</span>
                          <span class="pr-pred-score"><%= itm.prediction.scoreA %>-<%= itm.prediction.scoreB %></span>
                          <% if (itm.prediction.penalty_winner) { %>
                          <span class="pr-pred-pk">⚽ <%= itm.prediction.penalty_winner %></span>
                          <% } %>
                        </div>
                        <% } else { %>
                        <div class="pr-pred-display pr-pred-missed"><span class="pr-pred-label">لم تسجل توقعك</span></div>
                        <% } %>
                      <% } else { %>
                      <form method="POST" action="/predictions" class="pr-pred-form" id="prForm<%= itm.match.id %>">
                        <input type="hidden" name="matchId" value="<%= itm.match.id %>">
                        <div class="pr-score-inputs">
                          <input type="number" name="scoreA" value="<%= hasP ? itm.prediction.scoreA : '' %>" min="0" placeholder="0" required class="pr-score-input" <%= (lck||ended) ? 'disabled' : '' %> oninput="prTogglePenalty(this)">
                          <span class="pr-score-sep">-</span>
                          <input type="number" name="scoreB" value="<%= hasP ? itm.prediction.scoreB : '' %>" min="0" placeholder="0" required class="pr-score-input" <%= (lck||ended) ? 'disabled' : '' %> oninput="prTogglePenalty(this)">
                        </div>
                        <% if (itm.match.round >= 4) { %>
                        <div class="pr-penalty-pick" id="prPenalty<%= itm.match.id %>" style="display:none;">
                          <span class="pr-penalty-label">⚽ ركلات الترجيح</span>
                          <div class="pr-penalty-opts">
                            <label class="pr-penalty-opt <%= hasP && itm.prediction.penalty_winner === itm.match.teamA ? 'pr-penalty-selected' : '' %>" onclick="event.stopPropagation();this.querySelector('input').click()">
                              <input type="radio" name="penaltyWinner" value="<%= itm.match.teamA %>" style="display:none" <%= hasP && itm.prediction.penalty_winner === itm.match.teamA ? 'checked' : '' %> <%= (lck||ended) ? 'disabled' : '' %> onchange="var p=this.closest('.pr-penalty-pick');p.querySelectorAll('.pr-penalty-opt').forEach(function(l){l.classList.remove('pr-penalty-selected')});this.closest('.pr-penalty-opt').classList.add('pr-penalty-selected')">
                              <img src="/flags/<%= teamFlags[itm.match.teamA]||'unknown' %>.png" class="pr-penalty-flag" onerror="this.src='/flags/unknown.png'">
                              <span class="pr-penalty-name"><%= itm.match.teamA %></span>
                              <span class="pr-penalty-tick">✓</span>
                            </label>
                            <label class="pr-penalty-opt <%= hasP && itm.prediction.penalty_winner === itm.match.teamB ? 'pr-penalty-selected' : '' %>" onclick="event.stopPropagation();this.querySelector('input').click()">
                              <input type="radio" name="penaltyWinner" value="<%= itm.match.teamB %>" style="display:none" <%= hasP && itm.prediction.penalty_winner === itm.match.teamB ? 'checked' : '' %> <%= (lck||ended) ? 'disabled' : '' %> onchange="var p=this.closest('.pr-penalty-pick');p.querySelectorAll('.pr-penalty-opt').forEach(function(l){l.classList.remove('pr-penalty-selected')});this.closest('.pr-penalty-opt').classList.add('pr-penalty-selected')">
                              <img src="/flags/<%= teamFlags[itm.match.teamB]||'unknown' %>.png" class="pr-penalty-flag" onerror="this.src='/flags/unknown.png'">
                              <span class="pr-penalty-name"><%= itm.match.teamB %></span>
                              <span class="pr-penalty-tick">✓</span>
                            </label>
                          </div>
                        </div>
                        <% } %>
                        <div class="pr-form-actions">
                          <% if (lck) { %><span class="pr-status-btn pr-status-locked">مقفل</span>
                          <% } else if (hasP) { %><button type="submit" class="pr-save-btn">تعديل</button><span class="pr-status-btn pr-status-predicted">تم التوقع</span>
                          <% } else { %><button type="submit" class="pr-save-btn">حفظ</button><% } %>
                        </div>
                      </form>
                      <% } %>
                    </div>
                    <div class="pr-row-team pr-row-team-b">
                      <div class="pr-flag-wrap"><img src="/flags/<%= teamFlags[itm.match.teamB]||'unknown' %>.png" class="pr-flag" onerror="this.src='/flags/unknown.png'" /></div>
                      <span class="pr-team-name"><%= itm.match.teamB %></span>
                    </div>
                  </div>
                </div>
                <% }); %>
              </div>
            </div>
          <% }); %>
        </div>

        <% if (matches.length === 0) { %>
          <div class="pr-empty"><div class="pr-empty-icon">⚽</div><div class="pr-empty-title">لا توجد مباريات متاحة</div><div class="pr-empty-text">لم يتم نشر أي جولة بعد.</div></div>
        <% } %>

        </div><!-- end matches tab content (desktop) -->

        <!-- ===== Challenge Tab Content (Desktop) ===== -->
        <div class="pred-tab-content <%= activeTab === 'challenge' ? 'active' : '' %>" id="predTabContentChallengeDesktop">
          <div class="ch-inline">

            <div class="ch-inline-hero">
              <div class="ch-inline-hero-title">🏆 توقع واربح المزيد من النقاط</div>
              <div class="ch-inline-hero-desc">توقع مستقبل البطولة واحصل على نقاط إضافية عند صحة توقعاتك</div>
            </div>

            <% if (challengeConfig && challengeConfig.open) { %>
            <div class="ch-inline-countdown">
              <div class="ch-inline-countdown-lbl">⏳ الوقت المتبقي لإغلاق التحدي</div>
              <div class="ch-inline-countdown-val" id="chInlineCountdownDesktop">--:--:--</div>
            </div>
            <% } else { %>
            <div style="text-align:center;margin-bottom:20px;">
              <span class="ch-inline-closed">🔒 التحدي مغلق</span>
            </div>
            <% } %>

            <div class="ch-inline-info">
              <div class="ch-inline-info-title">📊 آلية احتساب النقاط</div>
              <div class="ch-inline-info-badges">
                <span class="ch-inline-info-badge">دور الـ8: 5 نقاط لكل منتخب</span>
                <span class="ch-inline-info-badge">دور الـ4: 10 نقاط لكل منتخب</span>
                <span class="ch-inline-info-badge">طرفا النهائي: 15 نقطة لكل منتخب</span>
                <span class="ch-inline-info-badge">البطل: 20 نقطة</span>
              </div>
            </div>

            <% if (challengeSaved) { %>
            <div class="ch-inline-saved">✅ تم حفظ توقعاتك بنجاح</div>
            <% } %>

            <% if (challengePicks && challengePicks.qf && challengeConfig && challengeConfig.open) { %>
            <div style="text-align:center;margin-bottom:16px;">
              <button type="button" class="ch-inline-edit-btn" onclick="chInlineToggleEditDesktop()">✏️ تعديل التوقعات</button>
              <div style="font-size:0.78rem;color:rgba(255,255,255,0.4);margin-top:4px;">تم حفظ توقعاتك سابقاً — يمكنك تعديلها حتى موعد الإغلاق</div>
            </div>
            <% } %>

            <div id="chInlineEditAreaDesktop" <%= (challengePicks && challengePicks.qf && challengeConfig && challengeConfig.open) ? 'style="display:none"' : '' %>>
            <form id="chInlineFormDesktop" method="POST" action="/challenge/save">
              <input type="hidden" name="source" value="predictions">

              <!-- Section 1: دور الـ8 -->
              <div class="ch-inline-section">
                <div class="ch-inline-section-title">🎯 توقع المنتخبات المتأهلة إلى دور الـ8</div>
                <div class="ch-inline-section-desc">اختر 8 منتخبات من القائمة</div>
                <span class="ch-inline-section-points">5 نقاط لكل منتخب صحيح</span>
                <div class="ch-inline-pick-info">
                  <span>المختار: <span class="ch-inline-pick-count" id="chInlineQfCountD">0</span>/8</span>
                </div>
                <div class="ch-inline-team-grid" id="chInlineQfGridD">
                  <% challengeTeams.forEach(function(t) { %>
                  <div class="ch-inline-team" data-team="<%= t %>" data-section="qf" onclick="chInlineToggleTeamD(this,'qf',8)">
                    <img src="/flags/<%= teamFlags[t] || 'unknown' %>.png" class="ch-inline-team-flag" onerror="this.style.display='none'">
                    <%= t %>
                    <input type="checkbox" name="qf" value="<%= t %>" style="display:none" <%= challengePicks && challengePicks.qf && challengePicks.qf.includes(t) ? 'checked' : '' %>>
                  </div>
                  <% }) %>
                </div>
              </div>

              <!-- Section 2: دور الـ4 -->
              <div class="ch-inline-section">
                <div class="ch-inline-section-title">🎯 توقع المنتخبات المتأهلة إلى دور الـ4</div>
                <div class="ch-inline-section-desc">اختر 4 منتخبات من القائمة</div>
                <span class="ch-inline-section-points">10 نقاط لكل منتخب صحيح</span>
                <div class="ch-inline-pick-info">
                  <span>المختار: <span class="ch-inline-pick-count" id="chInlineSfCountD">0</span>/4</span>
                </div>
                <div class="ch-inline-team-grid" id="chInlineSfGridD">
                  <% challengeTeams.forEach(function(t) { %>
                  <div class="ch-inline-team" data-team="<%= t %>" data-section="sf" onclick="chInlineToggleTeamD(this,'sf',4)">
                    <img src="/flags/<%= teamFlags[t] || 'unknown' %>.png" class="ch-inline-team-flag" onerror="this.style.display='none'">
                    <%= t %>
                    <input type="checkbox" name="sf" value="<%= t %>" style="display:none" <%= challengePicks && challengePicks.sf && challengePicks.sf.includes(t) ? 'checked' : '' %>>
                  </div>
                  <% }) %>
                </div>
              </div>

              <!-- Section 3: طرفا النهائي -->
              <div class="ch-inline-section">
                <div class="ch-inline-section-title">🎯 توقع طرفي المباراة النهائية</div>
                <div class="ch-inline-section-desc">اختر منتخبين</div>
                <span class="ch-inline-section-points">15 نقطة لكل منتخب صحيح</span>
                <div class="ch-inline-pick-info">
                  <span>المختار: <span class="ch-inline-pick-count" id="chInlineFinalistsCountD">0</span>/2</span>
                </div>
                <div class="ch-inline-team-grid" id="chInlineFinalistsGridD">
                  <% challengeTeams.forEach(function(t) { %>
                  <div class="ch-inline-team" data-team="<%= t %>" data-section="finalists" onclick="chInlineToggleTeamD(this,'finalists',2)">
                    <img src="/flags/<%= teamFlags[t] || 'unknown' %>.png" class="ch-inline-team-flag" onerror="this.style.display='none'">
                    <%= t %>
                    <input type="checkbox" name="finalists" value="<%= t %>" style="display:none" <%= challengePicks && challengePicks.finalists && challengePicks.finalists.includes(t) ? 'checked' : '' %>>
                  </div>
                  <% }) %>
                </div>
              </div>

              <!-- Section 4: البطل -->
              <div class="ch-inline-section">
                <div class="ch-inline-section-title">🏆 توقع بطل كأس العالم</div>
                <div class="ch-inline-section-desc">اختر منتخب واحد</div>
                <span class="ch-inline-section-points">20 نقطة إذا كان الاختيار صحيحاً</span>
                <div class="ch-inline-pick-info">
                  <span>المختار: <span class="ch-inline-pick-count" id="chInlineChampionCountD">0</span>/1</span>
                </div>
                <div class="ch-inline-team-grid" id="chInlineChampionGridD">
                  <% challengeTeams.forEach(function(t) { %>
                  <div class="ch-inline-team" data-team="<%= t %>" data-section="champion" onclick="chInlineToggleTeamD(this,'champion',1)">
                    <img src="/flags/<%= teamFlags[t] || 'unknown' %>.png" class="ch-inline-team-flag" onerror="this.style.display='none'">
                    <%= t %>
                    <input type="checkbox" name="champion" value="<%= t %>" style="display:none" <%= challengePicks && challengePicks.champion && challengePicks.champion === t ? 'checked' : '' %>>
                  </div>
                  <% }) %>
                </div>
              </div>

              <button type="submit" class="ch-inline-save-btn" id="chInlineSaveBtnD" <%= !challengeConfig || !challengeConfig.open ? 'disabled' : '' %>>
                <%= challengePicks && challengePicks.qf ? '💾 تحديث التوقعات' : '💾 حفظ التحدي' %>
              </button>
            </form>
            </div>

            <% if (!challengeConfig || !challengeConfig.open) { %>
            <% if (challengePicks && challengePicks.qf) { %>
            <div class="ch-inline-closed-stage">
              ✅ تم حفظ توقعاتك مسبقاً. هذه المرحلة غير متاحة حالياً للتعديل.
            </div>
            <% } else { %>
            <div class="ch-inline-closed-stage">
              هذه المرحلة غير متاحة حالياً
            </div>
            <% } %>
            <% } %>

          </div>
        </div><!-- end challenge tab content (desktop) -->

    </div>
  </section>
    </main>
  </div>

  <script>
    // ===== Tab Switching =====
    function predSwitchTab(tab) {
      // Update tab buttons (both mobile + desktop)
      document.querySelectorAll('.pred-tab').forEach(function(btn) {
        btn.classList.toggle('active',
          (btn.id === 'predTabMatches' || btn.id === 'predTabMatchesDesktop') && tab === 'matches' ||
          (btn.id === 'predTabChallenge' || btn.id === 'predTabChallengeDesktop') && tab === 'challenge'
        );
      });
      // Show/hide tab content (both mobile + desktop)
      document.querySelectorAll('.pred-tab-content').forEach(function(c) {
        var isMatches = c.id === 'predTabContentMatches' || c.id === 'predTabContentMatchesDesktop';
        var isChallenge = c.id === 'predTabContentChallenge' || c.id === 'predTabContentChallengeDesktop';
        c.classList.toggle('active', (tab === 'matches' && isMatches) || (tab === 'challenge' && isChallenge));
      });
      // Update URL without reload
      var url = new URL(window.location);
      url.searchParams.set('tab', tab);
      window.history.replaceState({}, '', url);
    }

    // ===== Challenge Inline (Mobile) =====
    var chInlineIsOpen = <%= (challengeConfig && challengeConfig.open) ? 'true' : 'false' %>;

    function chInlineToggleEdit() {
      var area = document.getElementById('chInlineEditArea');
      if (area) { area.style.display = 'block'; }
      var btn = event.target;
      if (btn) btn.style.display = 'none';
    }

    function chInlineToggleTeam(el, section, max) {
      if (!chInlineIsOpen) return;
      var chk = el.querySelector('input[type=checkbox]');
      var grid = document.getElementById(section + 'Grid');
      if (!grid) return;
      var selected = grid.querySelectorAll('.ch-inline-team.selected').length;
      if (chk.checked) {
        chk.checked = false;
        el.classList.remove('selected');
      } else {
        if (selected >= max) return;
        chk.checked = true;
        el.classList.add('selected');
      }
      chInlineUpdateCounts();
    }

    function chInlineUpdateCounts() {
      [['qf',8],['sf',4],['finalists',2],['champion',1]].forEach(function(pair) {
        var section = pair[0], max = pair[1];
        var grid = document.getElementById(section + 'Grid');
        if (!grid) return;
        var count = grid.querySelectorAll('.ch-inline-team.selected').length;
        var el = document.getElementById(section + 'Count');
        if (!el) return;
        el.textContent = count;
        el.className = 'ch-inline-pick-count';
        if (count === max) el.classList.add('valid');
        else el.classList.add('invalid');
      });
      var allValid = true;
      [['qf',8],['sf',4],['finalists',2],['champion',1]].forEach(function(pair) {
        var grid = document.getElementById(pair[0] + 'Grid');
        if (!grid) return;
        allValid = allValid && grid.querySelectorAll('.ch-inline-team.selected').length === pair[1];
      });
      var btn = document.getElementById('chInlineSaveBtn');
      if (btn) btn.disabled = !allValid || !chInlineIsOpen;
    }

    // ===== Challenge Inline (Desktop) =====
    function chInlineToggleEditDesktop() {
      var area = document.getElementById('chInlineEditAreaDesktop');
      if (area) { area.style.display = 'block'; }
      var btn = event.target;
      if (btn) btn.style.display = 'none';
    }

    function chInlineToggleTeamD(el, section, max) {
      if (!chInlineIsOpen) return;
      var chk = el.querySelector('input[type=checkbox]');
      var grid = document.getElementById(section + 'GridD');
      if (!grid) return;
      var selected = grid.querySelectorAll('.ch-inline-team.selected').length;
      if (chk.checked) {
        chk.checked = false;
        el.classList.remove('selected');
      } else {
        if (selected >= max) return;
        chk.checked = true;
        el.classList.add('selected');
      }
      chInlineUpdateCountsD();
    }

    function chInlineUpdateCountsD() {
      [['qf',8],['sf',4],['finalists',2],['champion',1]].forEach(function(pair) {
        var section = pair[0], max = pair[1];
        var grid = document.getElementById(section + 'GridD');
        if (!grid) return;
        var count = grid.querySelectorAll('.ch-inline-team.selected').length;
        var el = document.getElementById(section + 'CountD');
        if (!el) return;
        el.textContent = count;
        el.className = 'ch-inline-pick-count';
        if (count === max) el.classList.add('valid');
        else el.classList.add('invalid');
      });
      var allValid = true;
      [['qf',8],['sf',4],['finalists',2],['champion',1]].forEach(function(pair) {
        var grid = document.getElementById(pair[0] + 'GridD');
        if (!grid) return;
        allValid = allValid && grid.querySelectorAll('.ch-inline-team.selected').length === pair[1];
      });
      var btn = document.getElementById('chInlineSaveBtnD');
      if (btn) btn.disabled = !allValid || !chInlineIsOpen;
    }

    // ===== Challenge Countdown =====
    var chInlineDeadline = '<%= (challengeConfig && challengeConfig.deadline) ? challengeConfig.deadline : "" %>';
    if (chInlineIsOpen && chInlineDeadline) {
      var dl = new Date(chInlineDeadline + 'Z').getTime();
      function chInlineTick() {
        var diff = dl - Date.now();
        var els = [document.getElementById('chInlineCountdown'), document.getElementById('chInlineCountdownDesktop')];
        if (diff <= 0) {
          els.forEach(function(el) { if (el) el.textContent = '00:00:00'; });
          chInlineIsOpen = false;
          var sb = document.getElementById('chInlineSaveBtn');
          var sbD = document.getElementById('chInlineSaveBtnD');
          if (sb) sb.disabled = true;
          if (sbD) sbD.disabled = true;
          return;
        }
        var h = String(Math.floor(diff / 3600000)).padStart(2,'0');
        var m = String(Math.floor((diff % 3600000) / 60000)).padStart(2,'0');
        var s = String(Math.floor((diff % 60000) / 1000)).padStart(2,'0');
        var txt = h + ':' + m + ':' + s;
        els.forEach(function(el) { if (el) el.textContent = txt; });
      }
      chInlineTick();
      setInterval(chInlineTick, 1000);
    }

    // ===== Init challenge UI from server data =====
    document.addEventListener('DOMContentLoaded', function() {
      // Mobile: mark selected teams
      document.querySelectorAll('#chInlineEditArea .ch-inline-team input[type=checkbox]:checked').forEach(function(cb) {
        cb.parentElement.classList.add('selected');
      });
      chInlineUpdateCounts();

      // Desktop: mark selected teams
      document.querySelectorAll('#chInlineEditAreaDesktop .ch-inline-team input[type=checkbox]:checked').forEach(function(cb) {
        cb.parentElement.classList.add('selected');
      });
      chInlineUpdateCountsD();
    });

    // Desktop: View Toggle + Filter
    function prSetView(v){
      document.getElementById('pr-list-btn').classList.toggle('active',v==='list');
      document.getElementById('pr-grid-btn').classList.toggle('active',v==='grid');
      document.querySelectorAll('.pr-matches-list').forEach(function(el){ el.className='pr-matches-list'+(v==='grid'?' pr-grid-view':''); });
    }
    function prFilterRound(r, btn){
      document.querySelectorAll('.pr-filter-pill').forEach(function(b){b.classList.remove('active');});
      if (btn) btn.classList.add('active');
      document.querySelectorAll('.pr-round-group').forEach(function(g){ g.style.display=(r==='all'||g.dataset.round==r)?'':'none'; });
    }

    // Mobile: Stepper (old pc - kept for desktop fallback)
    function pcStep(id, side, delta) {
      var hid = document.getElementById('pc' + side + id);
      var display = document.getElementById('pcVal' + side + id);
      var cur = parseInt(hid.value) || 0;
      var next = Math.max(0, cur + delta);
      hid.value = next;
      display.textContent = next;
      var btn = document.getElementById('pcBtn' + id);
      if (btn) btn.innerHTML = 'حفظ التوقع';
    }
    function pcSubmit(id) {
      var a = parseInt(document.getElementById('pcA' + id).value) || 0;
      var b = parseInt(document.getElementById('pcB' + id).value) || 0;
      document.getElementById('pcA' + id).value = a;
      document.getElementById('pcB' + id).value = b;
      return true;
    }
    var pcIdx = 8;
    (function pcInit(){
      var cards = document.querySelectorAll('.pc-card');
      if (cards.length <= pcIdx) return;
      for (var i = pcIdx; i < cards.length; i++) cards[i].style.display = 'none';
      var sm = document.getElementById('pcShowMore');
      if (sm) sm.style.display = '';
    })();
    function pcLoadMore(){
      var cards = document.querySelectorAll('.pc-card');
      var end = Math.min(pcIdx + 8, cards.length);
      for (var i = pcIdx; i < end; i++) { cards[i].style.display = ''; }
      pcIdx = end;
      if (pcIdx >= cards.length) document.getElementById('pcShowMore').style.display = 'none';
    }

    // ===== PC2 Mobile V2 =====
    function pc2Step(id, side, delta) {
      var hid = document.getElementById('pc2' + side + id);
      var display = document.getElementById('pc2V' + side + id);
      var cur = parseInt(hid.value) || 0;
      var next = Math.max(0, cur + delta);
      hid.value = next;
      display.textContent = next;
      var btn = document.getElementById('pc2Btn' + id);
      if (btn) { btn.innerHTML = '<svg viewBox="0 0 24 24" fill="currentColor" width="15" height="15"><path d="M17 3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V7l-4-4zm-5 16c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3zm3-10H5V5h10v4z"/></svg> حفظ التوقع'; }
      // إظهار/إخفاء اختيار ركلات الترجيح عند التعادل
      pc2TogglePenalty(id);
    }
    function pc2TogglePenalty(id) {
      var a = parseInt(document.getElementById('pc2A' + id).value) || 0;
      var b = parseInt(document.getElementById('pc2B' + id).value) || 0;
      var el = document.getElementById('pc2Penalty' + id);
      if (el) {
        el.style.display = (a === b) ? 'flex' : 'none';
      }
    }
    // تفعيل ركلات الترجيح للتوقعات المحفوظة مسبقاً
    document.addEventListener('DOMContentLoaded', function(){
      document.querySelectorAll('[id^="pc2Penalty"]').forEach(function(el){
        var id = el.id.replace('pc2Penalty', '');
        if (id) pc2TogglePenalty(id);
      });
    });
    function pc2Submit(id) {
      var a = parseInt(document.getElementById('pc2A' + id).value) || 0;
      var b = parseInt(document.getElementById('pc2B' + id).value) || 0;
      document.getElementById('pc2A' + id).value = a;
      document.getElementById('pc2B' + id).value = b;
      return true;
    }

    // Round selector
    var pc2CurrentRound = null;
    function pc2ToggleRounds() {
      var dd = document.getElementById('pc2RoundDropdown');
      dd.style.display = dd.style.display === 'none' ? 'block' : 'none';
    }
    function pc2SelectRound(round, label) {
      document.getElementById('pc2RoundBtnLabel').textContent = label;
      document.getElementById('pc2RoundDropdown').style.display = 'none';
      document.querySelectorAll('.pc2-round-opt').forEach(function(b){
        b.classList.toggle('active', b.getAttribute('onclick').indexOf("'"+round+"'") !== -1);
      });
      document.querySelectorAll('.pc2-round-group').forEach(function(g){
        g.style.display = g.dataset.round == round ? 'block' : 'none';
      });
      pc2CurrentRound = round;
      pc2ResetShowMore();
    }
    // Init: show only first round
    (function pc2Init(){
      var groups = document.querySelectorAll('.pc2-round-group');
      if (groups.length > 1) {
        var first = groups[0].dataset.round;
        groups.forEach(function(g){ g.style.display = g.dataset.round == first ? 'block' : 'none'; });
        pc2CurrentRound = first;
      }
      pc2ResetShowMore();
    })();

    // Penalty winner toggle for desktop (pr) forms
    function prTogglePenalty(input) {
      var form = input.closest('.pr-pred-form');
      if (!form) return;
      var inputs = form.querySelectorAll('.pr-score-input');
      if (inputs.length < 2) return;
      var a = parseInt(inputs[0].value) || 0;
      var b = parseInt(inputs[1].value) || 0;
      var matchId = form.querySelector('input[name="matchId"]');
      if (!matchId) return;
      var penaltyEl = document.getElementById('prPenalty' + matchId.value);
      if (penaltyEl) {
        penaltyEl.style.display = (a === b) ? 'flex' : 'none';
      }
    }
    // Activate penalty pickers on load for saved predictions
    document.addEventListener('DOMContentLoaded', function(){
      document.querySelectorAll('.pr-pred-form').forEach(function(form){
        var inputs = form.querySelectorAll('.pr-score-input');
        if (inputs.length === 2 && inputs[0].value && inputs[1].value) {
          var a = parseInt(inputs[0].value) || 0;
          var b = parseInt(inputs[1].value) || 0;
          if (a === b) {
            var matchId = form.querySelector('input[name="matchId"]');
            if (matchId) {
              var penaltyEl = document.getElementById('prPenalty' + matchId.value);
              if (penaltyEl) penaltyEl.style.display = 'flex';
            }
          }
        }
      });
    });

    // Show more
    var pc2VisibleCount = 5;
    function pc2ResetShowMore() {
      pc2VisibleCount = 5;
      var cards = pc2VisibleCards();
      cards.forEach(function(c, i){ c.style.display = i < pc2VisibleCount ? '' : 'none'; });
      var sm = document.getElementById('pc2ShowMore');
      if (sm) sm.style.display = cards.length > pc2VisibleCount ? '' : 'none';
    }
    function pc2VisibleCards() {
      var activeGroup = pc2CurrentRound
        ? document.getElementById('pc2Group' + pc2CurrentRound)
        : document.querySelector('.pc2-round-group');
      if (!activeGroup) return [];
      return Array.from(activeGroup.querySelectorAll('.pc2-card'));
    }
    function pc2LoadMore() {
      var cards = pc2VisibleCards();
      var newCount = pc2VisibleCount + 5;
      cards.forEach(function(c, i){ if (i < newCount) c.style.display = ''; });
      pc2VisibleCount = newCount;
      if (pc2VisibleCount >= cards.length) document.getElementById('pc2ShowMore').style.display = 'none';
    }

    // ===== Date Filter Helpers =====
    function prGetTodayKey() {
      var d = new Date();
      return d.toLocaleDateString('en-CA', { timeZone: 'Asia/Riyadh' });
    }
    function prGetDateKey(offset) {
      var d = new Date();
      d.setDate(d.getDate() + offset);
      return d.toLocaleDateString('en-CA', { timeZone: 'Asia/Riyadh' });
    }
    function prMatchDateFilter(filter, matchDateKey) {
      if (filter === 'all') return true;
      var target;
      if (filter === 'today') target = prGetTodayKey();
      else if (filter === 'yesterday') target = prGetDateKey(-1);
      else if (filter === 'tomorrow') target = prGetDateKey(1);
      else return true;
      return matchDateKey === target;
    }

    // Desktop date filter
    function prDateFilter(dateFilter, btn) {
      document.querySelectorAll('.pr-date-filters .sc-date-pill').forEach(function(b){ b.classList.remove('active'); });
      btn.classList.add('active');
      prApplyFilters();
    }
    function prApplyFilters() {
      // Active filters
      var activeDatePill = document.querySelector('.pr-date-filters .sc-date-pill.active');
      var dateFilter = activeDatePill ? activeDatePill.getAttribute('data-pr-date') : 'all';
      var actRound = document.querySelector('#pr-filters .pr-filter-pill.active');
      var roundFilter = 'all';
      if (actRound) {
        var m = actRound.getAttribute('onclick');
        if (m) { var mr = m.match(/prFilterRound\(['"]?([^'"]+?)['"]?,\s*this\)/); if (mr) roundFilter = mr[1]; }
      }
      // Apply to desktop rows
      document.querySelectorAll('.pr-match-row').forEach(function(row){
        var d = row.getAttribute('data-pr-date');
        var r = row.getAttribute('data-round');
        var showDate = prMatchDateFilter(dateFilter, d);
        var showRound = (roundFilter === 'all' || r === roundFilter);
        row.style.display = (showDate && showRound) ? '' : 'none';
      });
      document.querySelectorAll('.pr-round-group').forEach(function(g){
        var vis = g.querySelectorAll('.pr-match-row:not([style*=\"display: none\"])');
        g.style.display = vis.length === 0 ? 'none' : '';
      });
    }
    // Override original round filter to apply date too
    var origRoundFilter = prFilterRound;
    function prFilterRound(r, btn) {
      document.querySelectorAll('#pr-filters .pr-filter-pill').forEach(function(b){ b.classList.remove('active'); });
      if (btn) btn.classList.add('active');
      prApplyFilters();
    }

    // Mobile date filter (PC2)
    function pc2DateFilter(dateFilter, btn) {
      document.querySelectorAll('[data-pc2-date]').forEach(function(b){
        if (b.classList.contains('ms-date-pill')) {
          b.classList.remove('active');
        }
      });
      btn.classList.add('active');
      pc2ApplyFilters();
    }
    function pc2ApplyFilters() {
      var activeDatePill = document.querySelector('.ms-date-pill.active[data-pc2-date]');
      var dateFilter = activeDatePill ? activeDatePill.getAttribute('data-pc2-date') : 'all';
      // Apply to visible cards (within current round)
      pc2VisibleCards().forEach(function(card){
        var d = card.getAttribute('data-pc2-date');
        card.style.display = prMatchDateFilter(dateFilter, d) ? '' : 'none';
      });
      pc2AfterFilter();
    }
    function pc2AfterFilter() {
      var cards = pc2VisibleCards();
      var visible = cards.filter(function(c){ return c.style.display !== 'none'; });
      var sm = document.getElementById('pc2ShowMore');
      if (sm) sm.style.display = visible.length > pc2VisibleCount ? '' : 'none';
      pc2CheckFilterEmpty();
    }
    function pc2CheckFilterEmpty() {
      var visible = pc2VisibleCards().filter(function(c){ return c.style.display !== 'none'; });
      var existing = document.getElementById('pc2FilterEmpty');
      if (visible.length === 0) {
        if (!existing) {
          var msg = document.createElement('div');
          msg.id = 'pc2FilterEmpty';
          msg.className = 'pc2-empty';
          msg.innerHTML = '<div class=\"pc2-empty-icon\">⚽</div><p>لا توجد مباريات تطابق الفلتر</p>';
          var container = document.querySelector('.pc2-round-group');
          if (container) container.appendChild(msg);
        } else { existing.style.display = ''; }
      } else {
        if (existing) existing.style.display = 'none';
      }
    }
    // Update PC2 show more to respect date filter
    function pc2VisibleCards() {
      var activeGroup = pc2CurrentRound
        ? document.getElementById('pc2Group' + pc2CurrentRound)
        : document.querySelector('.pc2-round-group');
      if (!activeGroup) return [];
      return Array.from(activeGroup.querySelectorAll('.pc2-card'));
    }
    function pc2ResetShowMore() {
      pc2VisibleCount = 5;
      var cards = pc2VisibleCards();
      var datePill = document.querySelector('.ms-date-pill.active[data-pc2-date]');
      var dateFilter = datePill ? datePill.getAttribute('data-pc2-date') : 'all';
      if (dateFilter === 'all') {
        cards.forEach(function(c, i){ c.style.display = i < pc2VisibleCount ? '' : 'none'; });
      } else {
        cards.forEach(function(c){ c.style.display = prMatchDateFilter(dateFilter, c.getAttribute('data-pc2-date')) ? '' : 'none'; });
        var visible = cards.filter(function(c){ return c.style.display !== 'none'; });
        visible.forEach(function(c, i){ c.style.display = i < pc2VisibleCount ? '' : 'none'; });
      }
      var visibleCards = cards.filter(function(c){ return c.style.display !== 'none'; });
      var sm = document.getElementById('pc2ShowMore');
      if (sm) sm.style.display = visibleCards.length > pc2VisibleCount ? '' : 'none';
      pc2CheckFilterEmpty();
    }
    function pc2LoadMore() {
      var cards = pc2VisibleCards().filter(function(c){ return c.style.display !== 'none'; });
      var newCount = pc2VisibleCount + 5;
      cards.forEach(function(c, i){ if (i < newCount) c.style.display = ''; });
      pc2VisibleCount = newCount;
      var allCards = pc2VisibleCards().filter(function(c){ return c.style.display !== 'none'; });
      if (pc2VisibleCount >= allCards.length) document.getElementById('pc2ShowMore').style.display = 'none';
    }

    // Close dropdown on outside click
    document.addEventListener('click', function(e){
      var sel = document.getElementById('pc2RoundSelector');
      if (sel && !sel.contains(e.target)) {
        var dd = document.getElementById('pc2RoundDropdown');
        if (dd) dd.style.display = 'none';
      }
    });
  </script>
<%- include('partials/mobile-nav', { active: 'predictions' }) %>
</body>
</html>
